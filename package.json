{
  "name": "imoji_magician_puzzle",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:math": "vitest run src/systems/__tests__/mathLevels",
    "test:english": "vitest run src/systems/__tests__/englishWords",
    "test:watch": "vitest watch",
    "agents": "node agents/game-team.mjs",
    "e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "e2e:smoke": "playwright test --config=tests/e2e/playwright.config.ts smoke/",
    "e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --headed",
    "e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "e2e:install": "playwright install --with-deps chromium webkit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-top-level-await": "^1.4.0",
    "vitest": "^2.0.0"
  }
}
